{ "npcId": "soulmate_012", "name": "心理学博士", "description": "29岁，心理学博士。能轻易看穿别人的谎言和伪装，对男方的真诚度和心理健康有极高要求，极度讨厌被欺骗。", "archetype": "SOULMATE", "stats": { "observation": 98, "materialism": 15, "romanticism": 70 }, "satisfactionThreshold": { "initial": 50, "fail": 0, "success": 85 }, "topicWeights": { "topic_psychological_defense": 3.0, "topic_childhood_trauma": 2.5, "topic_sincerity": 2.5, "topic_salary": 0.1, "topic_house": 0.1 }, "dialogueTree": { "topic_psychological_defense": { "topicId": "topic_psychological_defense", "question": "你觉得你是一个防御心很强的人吗？", "options": [ { "type": "TRUTH", "text": "我觉得我确实有点防御心，不太容易相信别人。", "effect": { "satisfaction": 20, "trust": 25 }, "riskCheck": false }, { "type": "LIE", "text": "我完全没有防御心，我对所有人都很真诚。", "effect": { "satisfaction": -20 }, "riskCheck": true }, { "type": "DEFLECT", "text": "你作为心理学博士，平时是怎么看穿别人的防御的？", "effect": { "satisfaction": 10 }, "riskCheck": false } ] }, "topic_childhood_trauma": { "topicId": "topic_childhood_trauma", "question": "你童年有什么创伤吗？", "options": [ { "type": "TRUTH", "text": "我童年过得挺普通的，没什么特别的创伤。", "effect": { "satisfaction": 10, "trust": 15 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我童年受过很多创伤，这是我的心理咨询记录。", "effect": { "satisfaction": 30 }, "itemRequired": "fake_counseling_record", "riskCheck": true } ] }, "topic_sincerity": { "topicId": "topic_sincerity", "question": "你觉得在感情中最重要的是什么？", "options": [ { "type": "TRUTH", "text": "我觉得是真诚和坦白，不能有任何欺骗。", "effect": { "satisfaction": 25, "trust": 20 }, "riskCheck": false }, { "type": "LIE", "text": "我觉得是互相包容和理解，偶尔善意的谎言也是可以的。", "effect": { "satisfaction": -15 }, "riskCheck": true } ] } } } 
