{ "npcId": "visualizer_012", "name": "古风圈顶流", "description": "23岁，古风圈知名博主。对古风文化有极度狂热的追求，要求男方必须有古典气质，最好能琴棋书画样样精通。", "archetype": "VISUALIZER", "stats": { "observation": 45, "materialism": 25, "romanticism": 95 }, "satisfactionThreshold": { "initial": 65, "fail": 0, "success": 85 }, "topicWeights": { "topic_ancient_style": 3.0, "topic_qin_qi_shu_hua": 2.5, "topic_appearance": 2.0, "topic_salary": 0.5, "topic_house": 0.5 }, "dialogueTree": { "topic_ancient_style": { "topicId": "topic_ancient_style", "question": "你平时喜欢听古风歌曲吗？", "options": [ { "type": "TRUTH", "text": "我平时很少听古风歌曲，觉得有点矫情。", "effect": { "satisfaction": -20, "trust": 15 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我非常喜欢，这是我收藏的古风黑胶唱片。", "effect": { "satisfaction": 35 }, "itemRequired": "fake_ancient_vinyl", "riskCheck": true }, { "type": "DEFLECT", "text": "你今天这身打扮真像从画里走出来的仙子。", "effect": { "satisfaction": 25 }, "riskCheck": false } ] }, "topic_qin_qi_shu_hua": { "topicId": "topic_qin_qi_shu_hua", "question": "你会弹古琴或者写书法吗？", "options": [ { "type": "TRUTH", "text": "我什么都不会，我就是个粗人。", "effect": { "satisfaction": -15, "trust": 10 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我从小练习书法，这是我写的字帖。", "effect": { "satisfaction": 40 }, "itemRequired": "fake_calligraphy", "riskCheck": true } ] }, "topic_appearance": { "topicId": "topic_appearance", "question": "你觉得你穿古装会好看吗？", "options": [ { "type": "TRUTH", "text": "我觉得我穿古装肯定很奇怪。", "effect": { "satisfaction": -10, "trust": 10 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我觉得我穿古装很有气质，这是我之前拍的古装写真。", "effect": { "satisfaction": 30 }, "itemRequired": "fake_ancient_photo", "riskCheck": true } ] } } } 
