{ "npcId": "pragmatist_004", "name": "相亲群里的刘姐", "description": "33岁，会计。精打细算，对每一笔开销都非常在意，看重男方的经济基础和消费观。", "archetype": "PRAGMATIST", "stats": { "observation": 70, "materialism": 85, "romanticism": 20 }, "satisfactionThreshold": { "initial": 40, "fail": 0, "success": 80 }, "topicWeights": { "topic_consumption": 3.0, "topic_savings": 2.5, "topic_house": 2.0, "topic_salary": 2.0, "topic_hobby": 0.5 }, "dialogueTree": { "topic_consumption": { "topicId": "topic_consumption", "question": "你平时每个月开销大概多少？", "options": [ { "type": "TRUTH", "text": "大概五六千吧，主要是吃饭和房租。", "effect": { "satisfaction": -10, "trust": 15 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我平时开销挺大的，这是我上个月的信用卡账单。", "effect": { "satisfaction": 30 }, "itemRequired": "fake_credit_bill", "riskCheck": true }, { "type": "DEFLECT", "text": "这家餐厅的菜挺实惠的，你觉得味道怎么样？", "effect": { "satisfaction": 10 }, "riskCheck": false } ] }, "topic_savings": { "topicId": "topic_savings", "question": "你现在有多少存款？", "options": [ { "type": "TRUTH", "text": "大概有十几万吧，还在努力攒钱。", "effect": { "satisfaction": -15, "trust": 10 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "大概有几百万吧，这是我的银行流水。", "effect": { "satisfaction": 40 }, "itemRequired": "fake_bank_statement", "riskCheck": true } ] }, "topic_house": { "topicId": "topic_house", "question": "你买房了吗？是全款还是贷款？", "options": [ { "type": "TRUTH", "text": "还没买，准备再攒几年首付。", "effect": { "satisfaction": -20, "trust": 10 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "全款买的，这是房产证。", "effect": { "satisfaction": 45 }, "itemRequired": "fake_house_deed", "riskCheck": true } ] } } } 
