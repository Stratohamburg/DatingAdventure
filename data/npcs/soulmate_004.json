{ "npcId": "soulmate_004", "name": "文艺女青年小青", "description": "27岁，自由撰稿人。心思细腻，追求灵魂的共鸣，对物质要求不高，但对精神世界要求极高。", "archetype": "SOULMATE", "stats": { "observation": 80, "materialism": 20, "romanticism": 80 }, "satisfactionThreshold": { "initial": 60, "fail": 0, "success": 85 }, "topicWeights": { "topic_literature": 3.0, "topic_music": 2.5, "topic_travel": 2.0, "topic_salary": 0.5, "topic_house": 0.5 }, "dialogueTree": { "topic_literature": { "topicId": "topic_literature", "question": "你最喜欢的作家是谁？", "options": [ { "type": "TRUTH", "text": "我平时很少看书，不太了解作家。", "effect": { "satisfaction": -15, "trust": 20 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我最喜欢马尔克斯，这是我收藏的他的全集。", "effect": { "satisfaction": 35 }, "itemRequired": "fake_book_collection", "riskCheck": true }, { "type": "DEFLECT", "text": "你平时写作的灵感都来自哪里？", "effect": { "satisfaction": 15 }, "riskCheck": false } ] }, "topic_music": { "topicId": "topic_music", "question": "你平时喜欢听什么类型的音乐？", "options": [ { "type": "TRUTH", "text": "我平时就听听流行歌曲。", "effect": { "satisfaction": -5, "trust": 15 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我喜欢听古典乐，这是我收藏的黑胶唱片。", "effect": { "satisfaction": 30 }, "itemRequired": "fake_vinyl", "riskCheck": true } ] }, "topic_travel": { "topicId": "topic_travel", "question": "你觉得旅行的意义是什么？", "options": [ { "type": "TRUTH", "text": "我觉得就是放松心情，吃吃喝喝。", "effect": { "satisfaction": 5, "trust": 15 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我觉得是体验不同的文化，这是我在西藏拍的照片。", "effect": { "satisfaction": 40 }, "itemRequired": "fake_tibet_photo", "riskCheck": true } ] } } } 
