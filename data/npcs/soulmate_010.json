{ "npcId": "soulmate_010", "name": "流浪歌手阿木", "description": "28岁，流浪歌手。四海为家，追求极致的自由和浪漫，对物质生活毫无概念，只看重灵魂的共鸣。", "archetype": "SOULMATE", "stats": { "observation": 70, "materialism": 0, "romanticism": 95 }, "satisfactionThreshold": { "initial": 70, "fail": 0, "success": 85 }, "topicWeights": { "topic_wandering": 3.0, "topic_music_creation": 2.5, "topic_freedom": 2.5, "topic_salary": 0.1, "topic_house": 0.1 }, "dialogueTree": { "topic_wandering": { "topicId": "topic_wandering", "question": "你愿意和我一起去流浪吗？", "options": [ { "type": "TRUTH", "text": "我不愿意，我觉得流浪太不切实际了，我需要稳定的生活。", "effect": { "satisfaction": -25, "trust": 20 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我非常愿意，这是我买的房车，我们可以开着它去流浪。", "effect": { "satisfaction": 40 }, "itemRequired": "fake_rv_key", "riskCheck": true }, { "type": "DEFLECT", "text": "你流浪了这么久，去过最美的地方是哪里？", "effect": { "satisfaction": 15 }, "riskCheck": false } ] }, "topic_music_creation": { "topicId": "topic_music_creation", "question": "你觉得音乐创作最重要的是什么？", "options": [ { "type": "TRUTH", "text": "我觉得是天赋和灵感。", "effect": { "satisfaction": 5, "trust": 15 }, "riskCheck": false }, { "type": "LIE", "text": "我觉得是真实的情感和对生活的感悟。", "effect": { "satisfaction": 25 }, "riskCheck": true } ] }, "topic_freedom": { "topicId": "topic_freedom", "question": "你觉得婚姻会束缚自由吗？", "options": [ { "type": "TRUTH", "text": "我觉得婚姻肯定会带来一些束缚，需要承担责任。", "effect": { "satisfaction": -10, "trust": 15 }, "riskCheck": false }, { "type": "LIE", "text": "我觉得真正的爱情是不会束缚自由的，反而会让人更自由。", "effect": { "satisfaction": 30 }, "riskCheck": true } ] } } } 
