{ "npcId": "pragmatist_010", "name": "离异带娃的王姐", "description": "35岁，离异带一孩。经历过婚姻的失败，更加看重男方的责任心、经济基础和对孩子的态度。", "archetype": "PRAGMATIST", "stats": { "observation": 85, "materialism": 80, "romanticism": 10 }, "satisfactionThreshold": { "initial": 30, "fail": 0, "success": 85 }, "topicWeights": { "topic_child": 3.0, "topic_responsibility": 2.5, "topic_economy": 2.5, "topic_hobby": 0.5, "topic_romance": 0.5 }, "dialogueTree": { "topic_child": { "topicId": "topic_child", "question": "你介意我带个孩子吗？你能把我的孩子当亲生的对待吗？", "options": [ { "type": "TRUTH", "text": "说实话，我心里还是有点介意的，但我会尽量对他好。", "effect": { "satisfaction": -20, "trust": 20 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "我完全不介意，我非常喜欢孩子，这是我给孩子买的学区房。", "effect": { "satisfaction": 45 }, "itemRequired": "fake_school_district_house", "riskCheck": true }, { "type": "DEFLECT", "text": "孩子平时乖吗？上几年级了？", "effect": { "satisfaction": 10 }, "riskCheck": false } ] }, "topic_responsibility": { "topicId": "topic_responsibility", "question": "你觉得在婚姻中，男人最重要的责任是什么？", "options": [ { "type": "TRUTH", "text": "我觉得是赚钱养家，给家人提供好的生活条件。", "effect": { "satisfaction": 10, "trust": 15 }, "riskCheck": false }, { "type": "LIE", "text": "我觉得是陪伴和包容，无论发生什么都不离不弃。", "effect": { "satisfaction": 25 }, "riskCheck": true } ] }, "topic_economy": { "topicId": "topic_economy", "question": "你现在的经济状况能承担起养两个孩子的压力吗？", "options": [ { "type": "TRUTH", "text": "目前可能有点困难，但我会努力赚钱的。", "effect": { "satisfaction": -25, "trust": 10 }, "riskCheck": false }, { "type": "LIE_ITEM", "text": "完全没问题，这是我的大额存单，足够我们一家人生活了。", "effect": { "satisfaction": 40 }, "itemRequired": "fake_large_deposit", "riskCheck": true } ] } } } 
